# Copy these into your .env (which is gitignored) and fill in real values.
# The notebook loads them automatically via python-dotenv.

OPENAI_API_KEY=sk-...

# Neo4j Aura: shown when you create the instance.
# URI looks like neo4j+s://<dbid>.databases.neo4j.io
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-aura-password
